# Virtualenv
venv/
env/
.venv/
ENV/

# VS Code
.vscode/
*.code-workspace

# Sistema operacional
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Testes e cobertura
.coverage
htmlcov/
.pytest_cache/

# Arquivos sensíveis
secrets.json
credentials.json
*.pem
*.key
*.p12

# Railway / Docker
.railway/